{
  "name": "student-ai-backend",
  "version": "1.0.0",
  "description": "Backend API for student management and AI prediction system",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "seed": "node src/scripts/seedData.js",
    "seed:large": "node src/scripts/seedLargeScaleData.js",
